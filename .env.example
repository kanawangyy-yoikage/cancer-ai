# .env.local — Salin file ini dan isi dengan nilai asli kamu
# JANGAN commit file .env.local ke Git!

# ── Firebase Configuration ──────────────────────────────────
# Dapatkan dari: https://console.firebase.google.com
# Project Settings > General > Your apps > Firebase SDK snippet

VITE_FIREBASE_API_KEY=AIzaSy_GANTI_DENGAN_API_KEY_FIREBASE_KAMU
VITE_FIREBASE_AUTH_DOMAIN=nama-project-kamu.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nama-project-kamu
VITE_FIREBASE_STORAGE_BUCKET=nama-project-kamu.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Catatan ────────────────────────────────────────────────
# Gemini API Key TIDAK disimpan di .env (disimpan di Firestore via Admin Panel)
# Ini agar API Key bisa diganti tanpa redeploy
